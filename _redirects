# Cloudflare Pages _redirects
# Redirect .html extension URLs to clean URLs (permanent)
# This catches any externally linked or bookmarked .html URLs
# and ensures Google and users always land on the canonical clean URL.

# Index pages
/index.html / 301

# Retired / merged pages (must come before the /*.html splat below)
# Limited Companies + LLPs merged into Who we work with
/limited-companies /who-we-work-with 301
/limited-companies.html /who-we-work-with 301
/llps /who-we-work-with 301
/llps.html /who-we-work-with 301
# Business Journey section retired
/business-journey / 301
/business-journey/ / 301
/business-journey/* / 301

# Splat redirect: any /*.html -> /* (strips extension)
# Note: Cloudflare Pages processes rules top-to-bottom, first match wins.
# The splat below handles all remaining .html -> clean URL redirects.
/*.html /:splat 301
